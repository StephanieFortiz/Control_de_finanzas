# Copia este archivo como secrets.toml y rellena con tus credenciales de Supabase.
# Encuéntralas en: Supabase → Settings → Database → Connection parameters
# NUNCA subas secrets.toml a GitHub — está en .gitignore.

[database]
host     = "db.XXXXXXXXXXXXXX.supabase.co"
port     = 5432
dbname   = "postgres"
user     = "postgres"
password = "tu-contraseña-sin-modificar"
